// Update the VARIANT arg in docker-compose.yml to pick a Node.js version
{
  "name": "Android & React Native",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces",
  "containerEnv": {
    "TZ": "America/Lima"
  },
  // Configure tool-specific properties.
  "customizations": {
    // Configure properties specific to VS Code.
    "vscode": {
      // Add the IDs of extensions you want installed when the container is created.
      "extensions": [
        "AlexShen.classdiagram-ts",
        "ChakrounAnas.turbo-console-log",
        "EditorConfig.EditorConfig",
        "Equinusocio.vsc-material-theme-icons",
        "GitHub.vscode-pull-request-github",
        "GraphQL.vscode-graphql",
        "GraphQL.vscode-graphql-syntax",
        "PKief.material-icon-theme",
        "aaron-bond.better-comments",
        "alefragnani.Bookmarks",
        "burkeholland.simple-react-snippets",
        "chouzz.vscode-better-align",
        "cschleiden.vscode-github-actions",
        "dbaeumer.vscode-eslint",
        "dsznajder.es7-react-js-snippets",
        "enkia.tokyo-night",
        "esbenp.prettier-vscode",
        "formulahendry.auto-close-tag",
        "formulahendry.auto-rename-tag",
        "github.vscode-github-actions",
        "jeff-hykin.better-dockerfile-syntax",
        "kamikillerto.vscode-colorize",
        "kisstkondoros.vscode-gutter-preview",
        "mhutchie.git-graph",
        "mikestead.dotenv",
        "moalamri.inline-fold",
        "mongodb.mongodb-vscode",
        "ms-azuretools.vscode-docker",
        "ms-vscode-remote.remote-containers",
        "oderwat.indent-rainbow",
        "pnp.polacode",
        "pflannery.vscode-versionlens",
        "pmneo.tsimporter",
        "quicktype.quicktype",
        "redhat.vscode-yaml",
        "rapidapi.vscode-services",
        "usernamehw.errorlens",
        "wayou.vscode-todo-highlight",
        "yuzu.snippets-next-13"
      ],
      // Configure terminal and shell settings for zsh
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "/bin/zsh",
            "icon": "terminal"
          },
          "bash": {
            "path": "/bin/bash",
            "icon": "terminal-bash"
          }
        },
        "terminal.integrated.shell.linux": "/bin/zsh"
      }
    }
  },
  // Use 'forwardPorts' to make a list of ports inside the container available locally.
  // "forwardPorts": [3000, 27017],
  // Use 'postCreateCommand' to run commands after the container is created.
  "postCreateCommand": "sh .devcontainer/scripts/configure-system.sh",
  // "postCreateCommand": "yarn install",
  // Comment out to connect as root instead. More info: https://aka.ms/vscode-remote/containers/non-root.
  "remoteUser": "node"
}
