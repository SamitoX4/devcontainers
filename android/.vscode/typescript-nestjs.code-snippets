  "NestJS CRUD Service": {
    "prefix": "nestjs-crud-service",
    "body": [
      "import { Injectable } from '@nestjs/common';",
      "import { Create${1:Entity}Dto } from './dto/create-${1:entity}.dto';",
      "import { Update${1:Entity}Dto } from './dto/update-${1:entity}.dto';",
      "",
      "@Injectable()",
      "export class ${1:Entity}Service {",
      "  private ${1:entityPlural}: any[] = []; // Simula base de datos en memoria",
      "",
      "  create(create${1:Entity}Dto: Create${1:Entity}Dto) {",
      "    const newItem = { id: Date.now().toString(), ...create${1:Entity}Dto };",
      "    this.${1:entityPlural}.push(newItem);",
      "    return { message: '${1:Entity} created successfully', data: newItem };",
      "  }",
      "",
      "  findAll() {",
      "    return this.${1:entityPlural};",
      "  }",
      "",
      "  findOne(id: string) {",
      "    const item = this.${1:entityPlural}.find((el) => el.id === id);",
      "    return item || { message: '${1:Entity} not found' };",
      "  }",
      "",
      "  update(id: string, update${1:Entity}Dto: Update${1:Entity}Dto) {",
      "    const index = this.${1:entityPlural}.findIndex((el) => el.id === id);",
      "    if (index === -1) return { message: '${1:Entity} not found' };",
      "    this.${1:entityPlural}[index] = { ...this.${1:entityPlural}[index], ...update${1:Entity}Dto };",
      "    return { message: '${1:Entity} updated successfully', data: this.${1:entityPlural}[index] };",
      "  }",
      "",
      "  remove(id: string) {",
      "    const index = this.${1:entityPlural}.findIndex((el) => el.id === id);",
      "    if (index === -1) return { message: '${1:Entity} not found' };",
      "    const deleted = this.${1:entityPlural}.splice(index, 1);",
      "    return { message: '${1:Entity} deleted successfully', data: deleted[0] };",
      "  }",
      "}"
    ],
    "description": "Servicio NestJS con métodos CRUD simulados (usando array como base de datos temporal)"
  },

