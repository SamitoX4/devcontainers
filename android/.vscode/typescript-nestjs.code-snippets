  "NestJS CRUD Service with TypeORM": {
    "prefix": "nestjs-crud-service-typeorm",
    "body": [
      "import { Injectable, NotFoundException } from '@nestjs/common';",
      "import { InjectRepository } from '@nestjs/typeorm';",
      "import { Repository } from 'typeorm';",
      "import { ${1:Entity} } from './entities/${2:entity}.entity';",
      "import { Create${1:Entity}Dto } from './dto/create-${2:entity}.dto';",
      "import { Update${1:Entity}Dto } from './dto/update-${2:entity}.dto';",
      "",
      "@Injectable()",
      "export class ${1:Entity}Service {",
      "  constructor(",
      "    @InjectRepository(${1:Entity})",
      "    private readonly ${2:entity}Repository: Repository<${1:Entity}>",
      "  ) {}",
      "",
      "  async create(create${1:Entity}Dto: Create${1:Entity}Dto) {",
      "    const newItem = this.${2:entity}Repository.create(create${1:Entity}Dto);",
      "    const savedItem = await this.${2:entity}Repository.save(newItem);",
      "    return { message: '${1:Entity} created successfully', data: savedItem };",
      "  }",
      "",
      "  async findAll() {",
      "    return await this.${2:entity}Repository.find();",
      "  }",
      "",
      "  async findOne(id: string) {",
      "    const item = await this.${2:entity}Repository.findOneBy({ id });",
      "    if (!item) throw new NotFoundException('${1:Entity} not found');",
      "    return item;",
      "  }",
      "",
      "  async update(id: string, update${1:Entity}Dto: Update${1:Entity}Dto) {",
      "    const result = await this.${2:entity}Repository.update(id, update${1:Entity}Dto);",
      "    if (result.affected === 0) throw new NotFoundException('${1:Entity} not found');",
      "    return { message: '${1:Entity} updated successfully' };",
      "  }",
      "",
      "  async remove(id: string) {",
      "    const result = await this.${2:entity}Repository.delete(id);",
      "    if (result.affected === 0) throw new NotFoundException('${1:Entity} not found');",
      "    return { message: '${1:Entity} deleted successfully' };",
      "  }",
      "}"
    ],
    "description": "Servicio NestJS con operaciones CRUD usando TypeORM Repository"
  },

