  "NestJS User Entity": {
    "prefix": "nestjs-user-entity",
    "body": [
      "// src/users/user.entity.ts",
      "import {",
      "  Entity,",
      "  Column,",
      "  PrimaryGeneratedColumn,",
      "  CreateDateColumn,",
      "  UpdateDateColumn,",
      "} from 'typeorm';",
      "",
      "// Decorador que indica que esta clase representa una entidad de la tabla 'users'",
      "@Entity('users')",
      "export class User {",
      "  // ID único generado automáticamente en formato UUID",
      "  @PrimaryGeneratedColumn('uuid')",
      "  id: string;",
      "",
      "  // Email del usuario (debe ser único)",
      "  @Column({ unique: true })",
      "  email: string;",
      "",
      "  // Contraseña en formato hash (puede estar vacía si el usuario se registró con Google o Facebook)",
      "  @Column({ nullable: true })",
      "  password_hash?: string;",
      "",
      "  // Estado del usuario: activo, inactivo o baneado",
      "  @Column({ default: 'active' })",
      "  status: 'active' | 'inactive' | 'banned';",
      "",
      "  // Proveedor de autenticación utilizado",
      "  @Column({ default: 'local' })",
      "  auth_provider: 'local' | 'google' | 'facebook';",
      "",
      "  // ID del proveedor externo (por ejemplo, Google ID)",
      "  @Column({ nullable: true })",
      "  provider_id?: string;",
      "",
      "  // Información del perfil en formato JSON (solo si aplica)",
      "  @Column('jsonb', { nullable: true })",
      "  profile?: {",
      "    first_name: string;",
      "    last_name: string;",
      "    bio: string;",
      "    profile_picture: string;",
      "    social_links: {",
      "      linkedin?: string;",
      "      twitter?: string;",
      "      website?: string;",
      "    };",
      "  };",
      "",
      "  // Fecha de creación (automáticamente manejada por TypeORM)",
      "  @CreateDateColumn()",
      "  created_at: Date;",
      "",
      "  // Fecha de última actualización (automáticamente manejada por TypeORM)",
      "  @UpdateDateColumn()",
      "  updated_at: Date;",
      "}"
    ],
    "description": "Entidad User completa con TypeORM y comentarios para NestJS"
  }
