  "AuthContext (Vite + React)": {
    "prefix": "vite-auth-context",
    "body": [
      "import { createContext, useContext, useEffect, useState } from 'react';",
      "import { login, verifyToken } from '@/api/auth';",
      "import { getUserById } from '@/api/users';",
      "import { getFromStorage, saveToStorage, removeFromStorage } from '@/utils/storage';",
      "",
      "interface AuthContextType {",
      "  user: any;",
      "  token: string | null;",
      "  signIn: (email: string, password: string) => Promise<void>;",
      "  signOut: () => void;",
      "}",
      "",
      "const AuthContext = createContext<AuthContextType | undefined>(undefined);",
      "",
      "export const AuthProvider = ({ children }: { children: React.ReactNode }) => {",
      "  const [token, setToken] = useState<string | null>(null);",
      "  const [user, setUser] = useState<any>(null);",
      "",
      "  useEffect(() => {",
      "    const storedToken = getFromStorage('token');",
      "    if (storedToken) {",
      "      verifyToken(storedToken)",
      "        .then((res) => {",
      "          setToken(storedToken);",
      "          setUser(res.user);",
      "        })",
      "        .catch(() => signOut());",
      "    }",
      "  }, []);",
      "",
      "  const signIn = async (email: string, password: string) => {",
      "    const { access_token } = await login({ email, password });",
      "    saveToStorage('token', access_token);",
      "    setToken(access_token);",
      "",
      "    const decoded: any = JSON.parse(atob(access_token.split('.')[1]));",
      "    const user = await getUserById(decoded.sub);",
      "    setUser(user);",
      "  };",
      "",
      "  const signOut = () => {",
      "    removeFromStorage('token');",
      "    setToken(null);",
      "    setUser(null);",
      "  };",
      "",
      "  return (",
      "    <AuthContext.Provider value={{ user, token, signIn, signOut }}>",
      "      {children}",
      "    </AuthContext.Provider>",
      "  );",
      "};",
      "",
      "export const useAuth = () => {",
      "  const context = useContext(AuthContext);",
      "  if (!context) throw new Error('useAuth must be used within AuthProvider');",
      "  return context;",
      "};"
    ],
    "description": "Contexto de autenticación para Vite + React"
  },

  "LocalStorage Utils": {
    "prefix": "vite-storage-utils",
    "body": [
      "export const saveToStorage = (key: string, value: string) => {",
      "  if (typeof window !== 'undefined') localStorage.setItem(key, value);",
      "};",
      "",
      "export const getFromStorage = (key: string): string | null => {",
      "  if (typeof window !== 'undefined') return localStorage.getItem(key);",
      "  return null;",
      "};",
      "",
      "export const removeFromStorage = (key: string) => {",
      "  if (typeof window !== 'undefined') localStorage.removeItem(key);",
      "};"
    ],
    "description": "Utilidades para localStorage con soporte para Vite + React (solo en cliente)"
  },

  "Auth API Functions (Vite + React)": {
    "prefix": "vite-api-auth",
    "body": [
      "import { http } from './httpClient';",
      "",
      "// Iniciar sesión",
      "export const login = (data: {",
      "  email: string;",
      "  password: string;",
      "}) =>",
      "  http.axios.post<{ access_token: string }>(",
      "    '/users/login',",
      "    data",
      "  );",
      "",
      "// Verificar token JWT",
      "export const verifyToken = (token: string) =>",
      "  http.axios.post(",
      "    '/auth/verify-token',",
      "    {},",
      "    {",
      "      headers: {",
      "        Authorization: `Bearer ${token}`",
      "      }",
      "    }",
      "  );",
      "",
      "// Iniciar sesión (ruta alternativa)",
      "export const loginUser = (data: {",
      "  email: string;",
      "  password: string;",
      "}) =>",
      "  http.axios.post<{ access_token: string }>(",
      "    '/login',",
      "    data",
      "  );"
    ],
    "description": "Funciones de autenticación: login y verifyToken con http.axios (Vite + React)"
  },

