{
  "httpClient.ts (Vite + Axios + Fetch)": {
    "prefix": "vite-api-http-client",
    "body": [
      "const baseUrl = import.meta.env.VITE_API_URL || '';",
      "",
      "interface HttpClient {",
      "  get<T = any>(url: string, options?: any): Promise<T>;",
      "  post<T = any>(url: string, data?: any, options?: any): Promise<T>;",
      "  put<T = any>(url: string, data?: any, options?: any): Promise<T>;",
      "  delete<T = any>(url: string, options?: any): Promise<T>;",
      "}",
      "",
      "const fetchClient: HttpClient = {",
      "  async get(url, options) {",
      "    const res = await fetch(`${baseUrl}${url}`, {",
      "      method: 'GET',",
      "      headers: options?.headers,",
      "    });",
      "    return res.json();",
      "  },",
      "  async post(url, data, options) {",
      "    const res = await fetch(`${baseUrl}${url}`, {",
      "      method: 'POST',",
      "      headers: {",
      "        'Content-Type': 'application/json',",
      "        ...(options?.headers || {}),",
      "      },",
      "      body: JSON.stringify(data),",
      "    });",
      "    return res.json();",
      "  },",
      "  async put(url, data, options) {",
      "    const res = await fetch(`${baseUrl}${url}`, {",
      "      method: 'PUT',",
      "      headers: {",
      "        'Content-Type': 'application/json',",
      "        ...(options?.headers || {}),",
      "      },",
      "      body: JSON.stringify(data),",
      "    });",
      "    return res.json();",
      "  },",
      "  async delete(url, options) {",
      "    const res = await fetch(`${baseUrl}${url}`, {",
      "      method: 'DELETE',",
      "      headers: options?.headers,",
      "    });",
      "    return res.json();",
      "  },",
      "};",
      "",
      "import axios from 'axios';",
      "",
      "const axiosInstance = axios.create({",
      "  baseURL: baseUrl,",
      "});",
      "",
      "const axiosClient: HttpClient = {",
      "  async get(url, options) {",
      "    const res = await axiosInstance.get(url, options);",
      "    return res.data;",
      "  },",
      "  async post(url, data, options) {",
      "    const res = await axiosInstance.post(url, data, options);",
      "    return res.data;",
      "  },",
      "  async put(url, data, options) {",
      "    const res = await axiosInstance.put(url, data, options);",
      "    return res.data;",
      "  },",
      "  async delete(url, options) {",
      "    const res = await axiosInstance.delete(url, options);",
      "    return res.data;",
      "  },",
      "};",
      "",
      "export const http = {",
      "  fetch: fetchClient,",
      "  axios: axiosClient,",
      "};"
    ],
    "description": "Plantilla para cliente HTTP con fetch y axios para Vite + React"
  },

