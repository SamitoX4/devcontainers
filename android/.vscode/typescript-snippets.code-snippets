  "Conexión MongoDB dividida (35 caracteres)": {
    "prefix": "mongodbconnect",
    "body": [
      "const {",
      "  ${1:DB_USER},",
      "  ${2:DB_PASS},",
      "  ${3:DB_HOST},",
      "  ${4:DB_PORT},",
      "  ${5:DB_NAME}",
      "} = process.env;",
      "",
      "const uri = `mongodb://` +",
      "  `${encodeURIComponent(${1:DB_USER})}:` +",
      "  `${encodeURIComponent(${2:DB_PASS})}@` +",
      "  `${${3:DB_HOST}}:` +",
      "  `${${4:DB_PORT}}/` +",
      "  `${${5:DB_NAME}};`",
      "",
      "await mongoose.connect(uri);",
      "console.log('Connected to MongoDB!');"
    ],
    "description": "Conexión a MongoDB con URI dividida en varias líneas (35 caracteres aprox.)"
  },

