{
  "Express Basic Server Setup": {
    "prefix": "express-server",
    "body": [
      "const express = require('express');",
      "const cors = require('cors');",
      "const app = express();",
      "",
      "// Basic Middlewares",
      "app.use(cors());",
      "app.use(express.json());",
      "",
      "// Route Test",
      "app.get('/', (req, res) => {",
      "  res.send('Blog Backend Working!');",
      "});",
      "",
      "// Global Issues Manager",
      "app.use((err, req, res, next) => {",
      "  console.error(err.stack);",
      "  res.status(500).json({ error: 'Something wrong on Server!' });",
      "});",
      "",
      "const PORT = process.env.PORT || 4000;",
      "app.listen(PORT, () => {",
      "  console.log(`Server run on http://localhost:${PORT}`);",
      "});"
    ],
    "description": "Create basic server express Snippet"
  }
}
