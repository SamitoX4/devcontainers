  "main.ts": {
    "prefix": "main",
    "body": [
      "// /src/main.ts",
      "import dotenv from \"dotenv\";",
      "import \"reflect-metadata\";",
      "dotenv.config();",
      "",
      "import cors from \"cors\";",
      "import listEndpoints from \"express-list-endpoints\";",
      "import { createApp } from \"./app.factory\";",
      "import { registerApp } from \"./app.module\";",
      "import {",
      "  PORT,",
      "  NODE_ENV,",
      "  APP_DOMAIN,",
      "} from \"./config/env.config\";",
      "import { ExampleController } from \"./modules/examples/examples.controller\";",
      "import { ROUTES_KEY } from \"./core/constants\";",
      "import {",
      "  connectToDatabase,",
      "  closeDatabaseConnection,",
      "} from \"./database/mongoose.connect\";",
      "",
      "let server:",
      "  | ReturnType<",
      "      typeof import(\"http\")[\"createServer\"]",
      "    >",
      "  | undefined;",
      "",
      "const startServer = async () => {",
      "  try {",
      "    await connectToDatabase();",
      "",
      "    const app = await createApp();",
      "    registerApp(app);",
      "",
      "    app.use(",
      "      cors({",
      "        origin:",
      "          NODE_ENV === \"production\"",
      "            ? APP_DOMAIN",
      "            : \"*\",",
      "        methods: [",
      "          \"GET\",",
      "          \"POST\",",
      "          \"PUT\",",
      "          \"DELETE\",",
      "        ],",
      "        allowedHeaders: [",
      "          \"Content-Type\",",
      "          \"Authorization\",",
      "        ],",
      "      })",
      "    );",
      "",
      "    const basePath = Reflect.getMetadata(",
      "      \"basePath\",",
      "      ExampleController",
      "    );",
      "    const routes = Reflect.getMetadata(",
      "      ROUTES_KEY,",
      "      ExampleController",
      "    );",
      "",
      "    console.log(",
      "      \"\ud83d\udd0d basePath metadata:\",",
      "      basePath",
      "    );",
      "    console.log(",
      "      \"\ud83d\udd0d routes metadata:\",",
      "      routes",
      "    );",
      "",
      "    console.log(\"\ud83d\udccb Rutas registradas:\");",
      "    console.table(listEndpoints(app));",
      "",
      "    server = app.listen(PORT, () => {",
      "      console.log(",
      "        `\ud83d\ude80 Server running on port ${PORT}`",
      "      );",
      "    });",
      "  } catch (err) {",
      "    console.error(",
      "      \"\u274c Error al iniciar el servidor:\",",
      "      err",
      "    );",
      "    process.exit(1);",
      "  }",
      "};",
      "",
      "const shutdown = async () => {",
      "  console.log(\"\\n\ud83d\uded1 Apagando el servidor...\");",
      "  try {",
      "    if (server && server.listening) {  // Usamos server.listening para verificar estado",
      "      await new Promise<void>((resolve, reject) => {",
      "        server!.close((err) => {",
      "          if (err) reject(err);",
      "          else resolve();",
      "        });",
      "      });",
      "      console.log(\"\u2705 Servidor cerrado correctamente.\");",
      "      server = undefined;  // Reseteamos la variable server",
      "    } else {",
      "      console.log(\"\u26a0\ufe0f El servidor no estaba corriendo o ya fue cerrado.\");",
      "    }",
      "",
      "    await closeDatabaseConnection();",
      "  } catch (err) {",
      "    console.error(\"\u274c Error durante el apagado:\", err);",
      "  } finally {",
      "    process.exit(0);",
      "  }",
      "};",
      "",
      "process.on(\"SIGINT\", shutdown);",
      "process.on(\"SIGTERM\", shutdown);",
      "",
      "startServer();"
    ],
    "description": "Snippet for main.ts"
  },
