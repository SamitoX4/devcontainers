  "decorators.ts": {
    "prefix": "decorators",
    "body": [
      "// /src/core/decorators.ts",
      "import 'reflect-metadata';",
      "",
      "import { ROUTES_KEY, PARAMS_KEY } from './constants'; // <-- Nuevo import",
      "",
      "export type RouteMethod = 'get' | 'post' | 'put' | 'delete' | 'patch' | 'options';",
      "",
      "// Tipos para par\u00e1metros",
      "type ParamType = 'body' | 'param' | 'query' | 'req' | 'res';",
      "interface ParamMetadata {",
      "  type: ParamType;",
      "  key?: string;",
      "  index: number;",
      "}",
      "",
      "// Decorador de controlador",
      "export function Controller(basePath: string = ''): ClassDecorator {",
      "  return (target) => {",
      "    Reflect.defineMetadata('basePath', basePath, target);",
      "    if (!Reflect.hasMetadata(ROUTES_KEY, target)) {",
      "      Reflect.defineMetadata(ROUTES_KEY, [], target);",
      "    }",
      "  };",
      "}",
      "",
      "// Factory para decoradores de m\u00e9todos HTTP",
      "function createMethodDecorator(method: RouteMethod) {",
      "  return (path: string = ''): MethodDecorator => {",
      "    return (target, propertyKey) => {",
      "      const controllerClass = target.constructor;",
      "      const routes: Array<{",
      "        method: RouteMethod;",
      "        path: string;",
      "        handlerName: string | symbol;",
      "      }> = Reflect.getMetadata(ROUTES_KEY, controllerClass) || [];",
      "",
      "      routes.push({ method, path, handlerName: propertyKey });",
      "      Reflect.defineMetadata(ROUTES_KEY, routes, controllerClass);",
      "    };",
      "  };",
      "}",
      "",
      "// Decoradores de m\u00e9todos HTTP",
      "export const Get = createMethodDecorator('get');",
      "export const Post = createMethodDecorator('post');",
      "export const Put = createMethodDecorator('put');",
      "export const Delete = createMethodDecorator('delete');",
      "export const Patch = createMethodDecorator('patch');",
      "export const Options = createMethodDecorator('options');",
      "",
      "// Factory para decoradores de par\u00e1metros",
      "function createParamDecorator(type: ParamType, key?: string) {",
      "  return (target: Object, propertyKey: string | symbol, parameterIndex: number) => {",
      "    const params: ParamMetadata[] = Reflect.getMetadata(PARAMS_KEY, target, propertyKey) || [];",
      "",
      "    params.push({",
      "      type,",
      "      key,",
      "      index: parameterIndex",
      "    });",
      "",
      "    Reflect.defineMetadata(PARAMS_KEY, params, target, propertyKey);",
      "  };",
      "}",
      "",
      "// Decoradores de par\u00e1metros",
      "export const Body = (key?: string) => createParamDecorator('body', key);",
      "export const Param = (key: string) => createParamDecorator('param', key);",
      "export const Query = (key: string) => createParamDecorator('query', key);",
      "export const Req = () => createParamDecorator('req');",
      "export const Res = () => createParamDecorator('res');"
    ],
    "description": "Snippet for decorators.ts"
  },
  "param-decorators.ts": {
    "prefix": "param-decorators",
    "body": [
      "// /src/core/param-decorators.ts",
      "import 'reflect-metadata';",
      "import { PARAMS_KEY } from './constants';",
      "",
      "type ParamType = 'body' | 'param' | 'query' | 'req' | 'res';",
      "",
      "function createParamDecorator(type: ParamType, key?: string) {",
      "  return (target: any, propertyKey: string | symbol, parameterIndex: number) => {",
      "    const existingParams = Reflect.getMetadata(PARAMS_KEY, target, propertyKey) || [];",
      "    existingParams.push({ index: parameterIndex, type, key });",
      "    Reflect.defineMetadata(PARAMS_KEY, existingParams, target, propertyKey);",
      "  };",
      "}",
      "",
      "export const Body = () => createParamDecorator('body');",
      "export const Param = (key: string) => createParamDecorator('param', key);",
      "export const Query = (key: string) => createParamDecorator('query', key);",
      "export const Req = () => createParamDecorator('req');",
      "export const Res = () => createParamDecorator('res');"
    ],
    "description": "Snippet for param-decorators.ts"
  },
  "registerControllers.ts": {
    "prefix": "registerControllers",
    "body": [
      "// /src/core/registerControllers.ts",
      "import {",
      "  Request,",
      "  Response,",
      "} from \"express\";",
      "import {",
      "  ROUTES_KEY,",
      "  PARAMS_KEY,",
      "} from \"./constants\";",
      "",
      "export function registerControllers(",
      "  app: any,",
      "  controllers: any[]",
      ") {",
      "  controllers.forEach((ControllerClass) => {",
      "    const instance = new ControllerClass();",
      "    const basePath = Reflect.getMetadata(",
      "      \"basePath\",",
      "      ControllerClass",
      "    );",
      "    const routes =",
      "      Reflect.getMetadata(",
      "        ROUTES_KEY,",
      "        ControllerClass",
      "      ) || [];",
      "",
      "    console.log(",
      "      `\ud83d\udce6 Registrando controlador: ${ControllerClass.name}`",
      "    );",
      "    console.log(`\ud83d\udd17 BasePath: ${basePath}`);",
      "    console.log(`\ud83d\udccb Rutas:`, routes);",
      "",
      "    routes.forEach((route: any) => {",
      "      const fullPath = basePath + route.path;",
      "",
      "      app[route.method.toLowerCase()](",
      "        fullPath,",
      "        async (",
      "          req: Request,",
      "          res: Response",
      "        ) => {",
      "          try {",
      "            const handler =",
      "              instance[",
      "                route.handlerName",
      "              ].bind(instance);",
      "            const metadata =",
      "              Reflect.getMetadata(",
      "                PARAMS_KEY,",
      "                instance,",
      "                route.handlerName",
      "              ) || [];",
      "",
      "            const args: any = [];",
      "",
      "            metadata.forEach(",
      "              (param: any) => {",
      "                switch (param.type) {",
      "                  case \"body\":",
      "                    args[param.index] =",
      "                      req.body;",
      "                    break;",
      "                  case \"param\":",
      "                    args[param.index] =",
      "                      req.params[param.key];",
      "                    break;",
      "                  case \"query\":",
      "                    args[param.index] =",
      "                      req.query[param.key];",
      "                    break;",
      "                  case \"req\":",
      "                    args[param.index] = req;",
      "                    break;",
      "                  case \"res\":",
      "                    args[param.index] = res;",
      "                    break;",
      "                  default:",
      "                    args[param.index] =",
      "                      undefined;",
      "                }",
      "              }",
      "            );",
      "",
      "            const result = await handler(",
      "              ...args",
      "            );",
      "            if (",
      "              !res.headersSent &&",
      "              result !== undefined",
      "            ) {",
      "              res.json(result);",
      "            }",
      "          } catch (err: any) {",
      "            res",
      "              .status(500)",
      "              .json({ error: err.message });",
      "          }",
      "        }",
      "      );",
      "    });",
      "  });",
      "}"
    ],
    "description": "Snippet for registerControllers.ts"
  },
